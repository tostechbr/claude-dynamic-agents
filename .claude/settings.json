{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/verify-agents.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "*"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf*)",
      "Bash(git branch -D*)",
      "mcp__github__merge_pull_request",
      "mcp__github__delete_branch"
    ]
  }
}
